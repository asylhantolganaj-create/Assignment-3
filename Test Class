import java.util.Random;

public class MainTest {
    public static void main(String[] args) {
        // Part 1.2 Testing HashTable
        MyHashTable<MyTestingClass, Student> table = new MyHashTable<>();

        Random rand = new Random();
        for (int i = 0; i < 10000; i++) {
            int id = rand.nextInt(1000);
            MyTestingClass key = new MyTestingClass(id, "Name" + id);
            Student value = new Student("Student" + id, id);
            table.put(key, value);
        }

        int[] buckets = table.getBucketSizes();
        System.out.println("=== HashTable Bucket Distribution ===");
        for (int i = 0; i < buckets.length; i++) {
            System.out.println("Bucket " + i + ": " + buckets[i] + " elements");
        }

        // Part 2.2 Testing BST
        System.out.println("\n=== BST Testing ===");
        BST<Integer, String> bst = new BST<>();

        bst.put(5, "Five");
        bst.put(3, "Three");
        bst.put(7, "Seven");
        bst.put(1, "One");
        bst.put(9, "Nine");

        System.out.println("Size: " + bst.size());
        System.out.println("Get 3: " + bst.get(3));

        System.out.println("\nIn-order Traversal:");
        for (var elem : bst.iterator()) {
            System.out.println("key is " + elem.getKey() + " and value is " + elem.getValue());
        }

        bst.delete(3);
        System.out.println("\nAfter deleting key 3:");
        for (var elem : bst.iterator()) {
            System.out.println("key is " + elem.getKey() + " and value is " + elem.getValue());
        }
        System.out.println("New size: " + bst.size());
    }
}
